# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe (server-side only, for Edge Functions)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPay (server-side only, for Edge Functions)
# 取得先: https://developer.paypay.ne.jp/ ダッシュボード
PAYPAY_API_KEY=a_xxxxxxxxxxxxxx
PAYPAY_API_SECRET=xxxxxxxxxxxxxx
PAYPAY_MERCHANT_ID=21111111111
PAYPAY_ENV=sandbox
# アプリへ戻るディープリンク（app.json の scheme と一致させる）
APP_REDIRECT_URL=moveact://shop/orders

# LINEログイン（顧客認証）
# クライアント側: LINE Login チャネルの Channel ID（公開可）
EXPO_PUBLIC_LINE_LOGIN_CHANNEL_ID=1234567890
# サーバー側(Supabase Function secrets): LINE Login チャネルの ID と Secret
#   supabase secrets set LINE_LOGIN_CHANNEL_ID=... LINE_LOGIN_CHANNEL_SECRET=...
LINE_LOGIN_CHANNEL_ID=1234567890
LINE_LOGIN_CHANNEL_SECRET=xxxxxxxxxxxxxxxx
